# --- Mandatory ---
# Get your key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# --- Optional (HuggingFace) ---
# Useful if you encounter rate limits during model downloads
# To get your Hugging Face Token, follow these steps:

# Go to Hugging Face: Open huggingface.co and log in.
# Open Settings: Click on your profile picture in the top right corner and select Settings.
# Access Tokens: On the left sidebar, click on Access Tokens.
# Create New Token:
# Click the "New token" button.
# Name: You can call it Healthcare-Assistant.
# Type: Choose Read .
HF_TOKEN=your_huggingface_token_here

# --- Optional (LangSmith Tracing) ---
# Highly recommended for debugging LangGraph flows
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT="Healthcare-Assistant"

